# Copy this file to .env before running local Make targets.
# .env is gitignored; never commit secrets or machine-local overrides.

# --- Database ---
# Host port used by docker-compose for the local TimescaleDB container.
# 5433 avoids collisions with a local Postgres server on 5432.
POSTGRES_HOST_PORT=5433

# Host-side URL used by local scripts and Make targets.
# Inside Docker, services use db:5432 from docker-compose.yaml instead.
DATABASE_URL=postgresql+psycopg://pitwall:pitwall@localhost:5433/pitwall

# --- Backend ---
LOG_LEVEL=INFO

# Keep scipy as the default until runtime XGBoost prediction and comparative
# backtest results justify changing ADR 0009.
PACE_PREDICTOR=scipy

# Demo replay defaults used by local scripts and frontend controls.
REPLAY_DEFAULT_SESSION=monaco_2024_R
REPLAY_DEFAULT_SPEED=30

# --- Data paths ---
# FastF1 writes cache files here. First uncached runs can be slow and large.
FASTF1_CACHE_DIR=data/cache
PITWALL_PROCESSED_DIR=data/processed

# --- Frontend (Vite) ---
# Browser-facing URLs for local development and docker-compose demo.
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/ws/v1/live
